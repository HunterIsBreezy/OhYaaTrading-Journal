rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Verification codes collection (managed by Cloud Functions only)
    match /verificationCodes/{codeId} {
      allow read, write: if false;
    }
    
    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && 
        resource.data.mentorId == request.auth.uid;
      
      match /journalData/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(userId)).data.mentorId == request.auth.uid;
      }
      
      match /tradeFeedback/{feedbackId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(userId)).data.mentorId == request.auth.uid;
      }
      
      match /tradeFlags/{flagId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(userId)).data.mentorId == request.auth.uid;
      }
      
      match /tradeQuestions/{questionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(userId)).data.mentorId == request.auth.uid;
      }
      
      match /assignments/{assignmentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(userId)).data.mentorId == request.auth.uid;
      }
      
      match /weeklyCheckins/{checkinId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(userId)).data.mentorId == request.auth.uid;
      }
      
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null && 
          get(/databases/$(database)/documents/users/$(userId)).data.mentorId == request.auth.uid;
      }
      
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }
    
    match /mentorInvites/{inviteId} {
      allow read, write: if request.auth != null;
    }
    
    match /mentorships/{mentorId} {
      allow read, write: if request.auth != null && request.auth.uid == mentorId;
      
      match /mentees/{menteeId} {
        allow read, write: if request.auth != null && request.auth.uid == mentorId;
        allow read, write: if request.auth != null && request.auth.uid == menteeId;
      }
      
      match /students/{studentId} {
        allow read, write: if request.auth != null && request.auth.uid == mentorId;
        allow read, write: if request.auth != null && request.auth.uid == studentId;
      }
    }
  }
}
